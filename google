  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue:   #4285F4;
      --red:    #EA4335;
      --yellow: #FBBC05;
      --green:  #34A853;
      --blue-dark:  #1a5fbe;
      --blue-light: #e8f0fe;
      --blue-mid:   #c5d9fd;
      --text:   #202124;
      --muted:  #5f6368;
      --border: #dadce0;
      --white:  #ffffff;
      --bg:     #f8f9fa;
    }

    body {
      font-family: 'Google Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      font-size: 15px;
    }

    /* ── HEADER ── */
    header {
      background: var(--blue);
      color: var(--white);
      padding: 48px 24px 36px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    /* subtle Google-dot watermark */
    header::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 12% 30%, rgba(251,188,5,.18) 60px, transparent 61px),
        radial-gradient(circle at 88% 25%, rgba(52,168,83,.15) 80px, transparent 81px),
        radial-gradient(circle at 75% 80%, rgba(234,67,53,.13) 70px, transparent 71px);
      pointer-events: none;
    }
    header > * { position: relative; }
    header h1 {
      font-size: clamp(26px, 5vw, 40px);
      font-weight: 700;
      letter-spacing: 0.3px;
    }
    header .title {
      font-size: clamp(13px, 2.5vw, 16px);
      margin-top: 6px;
      color: #c9dcfd;
      font-weight: 400;
    }

    /* Google dot divider */
    .google-dots {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 6px;
      margin: 18px 0 16px;
    }
    .google-dots span {
      width: 9px; height: 9px;
      border-radius: 50%;
      display: inline-block;
    }
    .dot-b { background: var(--blue-mid); }
    .dot-r { background: #f5a29c; }
    .dot-y { background: #fdd982; }
    .dot-g { background: #91d7a8; }

    .contact-bar {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px 22px;
    }
    .contact-bar a {
      color: #c9dcfd;
      text-decoration: none;
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: color .15s;
    }
    .contact-bar a:hover { color: var(--white); }

    /* ── LAYOUT ── */
    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 28px 16px 64px;
    }

    /* ── SECTION ── */
    .section {
      background: var(--white);
      border-radius: 12px;
      border: 1px solid var(--border);
      padding: 28px 28px 24px;
      margin-bottom: 20px;
      box-shadow: 0 1px 3px rgba(60,64,67,.08);
    }
    .section-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 2px solid var(--blue-mid);
    }
    .section-icon {
      width: 34px; height: 34px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .section-icon svg { fill: var(--white); width: 17px; height: 17px; }
    .section-header h2 {
      font-size: 13.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.2px;
      color: var(--blue);
    }

    /* colour variants for section icons */
    .icon-blue   { background: var(--blue); }
    .icon-green  { background: var(--green); }
    .icon-red    { background: var(--red); }
    .icon-yellow { background: var(--yellow); }

    /* ── PROFILE ── */
    .profile-body { border-left: 3px solid var(--blue); padding-left: 18px; }
    .profile-text { color: var(--muted); line-height: 1.8; font-size: 14.5px; }
    .profile-text + .profile-text { margin-top: 13px; }

    /* ── SKILLS ── */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }
    .skill-group h3 {
      font-size: 11.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }
    .skill-group.sg-sales h3   { color: var(--blue); }
    .skill-group.sg-marketing h3 { color: var(--green); }
    .skill-group.sg-leadership h3 { color: var(--red); }
    .skill-group.sg-travel h3  { color: #e37400; }

    .tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag {
      padding: 4px 11px;
      border-radius: 20px;
      font-size: 12.5px;
      font-weight: 500;
      border: 1px solid;
    }
    .tag-blue   { background: var(--blue-light); color: var(--blue-dark); border-color: var(--blue-mid); }
    .tag-green  { background: #e6f4ea; color: #1e7e34; border-color: #a8d5b5; }
    .tag-red    { background: #fce8e6; color: #b31412; border-color: #f5b7b1; }
    .tag-yellow { background: #fef7e0; color: #7a5900; border-color: #fdd77e; }

    /* ── EXPERIENCE ── */
    .job { margin-bottom: 28px; }
    .job:last-child { margin-bottom: 0; }
    .job-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 6px;
    }
    .job-company { font-weight: 700; font-size: 15.5px; color: var(--text); }
    .job-role    { font-size: 13.5px; color: var(--blue); font-weight: 600; margin-top: 2px; }
    .job-date {
      font-size: 12.5px;
      color: var(--muted);
      white-space: nowrap;
      background: var(--blue-light);
      border: 1px solid var(--blue-mid);
      border-radius: 20px;
      padding: 3px 10px;
    }
    .job-scope { font-size: 13px; color: var(--muted); margin: 8px 0 6px; font-style: italic; }
    .job ul {
      margin: 6px 0 6px 4px;
      padding-left: 18px;
      color: var(--muted);
      font-size: 13.5px;
    }
    .job ul li { margin-bottom: 4px; }
    .achievements-label {
      font-size: 11.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.9px;
      color: var(--green);
      margin: 10px 0 4px;
    }
    .job-divider { border: none; border-top: 1px solid #f1f3f4; margin: 24px 0; }

    /* ── EARLY CAREER ── */
    .early-career {
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid var(--border);
    }
    .early-row {
      display: grid;
      grid-template-columns: 1fr auto 130px;
      gap: 12px;
      padding: 10px 14px;
      font-size: 13.5px;
      align-items: center;
    }
    .early-row:not(:last-child) { border-bottom: 1px solid var(--border); }
    .early-row:nth-child(odd)   { background: var(--bg); }
    .early-row:nth-child(even)  { background: var(--white); }
    .early-company { font-weight: 600; color: var(--text); }
    .early-role    { color: var(--muted); font-size: 13px; }
    .early-date    { color: var(--muted); font-size: 12.5px; text-align: right; }

    /* ── CARDS (edu / cert) ── */
    .two-col { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; }
    .card {
      border-radius: 10px;
      padding: 14px 16px;
      border-left: 4px solid;
    }
    .card-blue   { background: var(--blue-light); border-color: var(--blue); }
    .card-green  { background: #e6f4ea; border-color: var(--green); }
    .card-red    { background: #fce8e6; border-color: var(--red); }
    .card-yellow { background: #fef7e0; border-color: var(--yellow); }
    .card h3   { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 2px; }
    .card .sub { font-size: 13px; color: var(--muted); margin-bottom: 4px; }
    .card .date{ font-size: 12px; font-weight: 600; color: var(--blue); }
    .card-green  .date { color: var(--green); }
    .card-red    .date { color: var(--red); }
    .card-yellow .date { color: #b06000; }

    /* ── LANGUAGES ── */
    .lang-list { display: flex; flex-wrap: wrap; gap: 12px; }
    .lang-item {
      display: flex; align-items: center; gap: 10px;
      background: var(--blue-light);
      border: 1px solid var(--blue-mid);
      border-radius: 10px;
      padding: 12px 18px;
      min-width: 160px;
    }
    .lang-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .lang-name  { font-weight: 700; font-size: 14px; color: var(--text); }
    .lang-level { font-size: 12.5px; color: var(--muted); }

    /* ── FOOTER ── */
    footer {
      text-align: center;
      padding: 20px 16px 32px;
      font-size: 12px;
      color: #9aa0a6;
    }
    footer a { color: var(--blue); text-decoration: none; }

    @media (max-width: 600px) {
      header { padding: 32px 16px 24px; }
      .section { padding: 20px 16px; }
      .job-header { flex-direction: column; align-items: flex-start; }
      .early-row { grid-template-columns: 1fr; gap: 2px; }
      .early-date { text-align: left; }
    }
  </style>
</head>
